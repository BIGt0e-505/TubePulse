{
  "expo": {
    "name": "TubePulse",
    "slug": "TubePulse",
    "version": "1.0.14",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121212"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.tubepulse.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#121212"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications",
      "./plugins/withForegroundService",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "TubePulseWidget",
              "label": "TubePulse",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "resizeMode": "horizontal|vertical",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "description": "YouTube channel update tracker",
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c90a6a0b-2f16-4a95-aa75-51a7f5c9313b"
      }
    },
    "owner": "bigt0e"
  }
}
